datasource db {
  provider = "sqlite"
}

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

enum Role {
  STUDENT
  TEACHER
}

model User {
  id               String            @id @default(cuid())
  email            String            @unique
  name             String
  password         String
  role             Role              @default(STUDENT)
  dailyGoal        Int               @default(20)
  students         User[]            @relation("TeacherStudents")
  teachers         User[]            @relation("TeacherStudents")
  progress         Progress[]
  wordSets         WordSet[]
  trainingSessions TrainingSession[]
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
}

model WordSet {
  id               String            @id @default(cuid())
  title            String
  user             User?             @relation(fields: [userId], references: [id])
  userId           String?
  words            Word[]
  progress         Progress[]
  trainingSessions TrainingSession[]
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
}

model Word {
  id            String     @id @default(cuid())
  term          String
  definition    String
  transcription String?
  wordSet       WordSet    @relation(fields: [wordSetId], references: [id])
  wordSetId     String
  progress      Progress[]
  createdAt     DateTime   @default(now())
}

model Progress {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  wordSet   WordSet  @relation(fields: [wordSetId], references: [id])
  wordSetId String
  word      Word     @relation(fields: [wordId], references: [id])
  wordId    String
  score     Int      @default(0)
  updatedAt DateTime @updatedAt

  @@unique([userId, wordId])
}

model TrainingSession {
  id          String   @id @default(cuid())
  user        User     @relation(fields: [userId], references: [id])
  userId      String
  wordSet     WordSet  @relation(fields: [wordSetId], references: [id])
  wordSetId   String
  totalWords  Int
  knownWords  Int
  completedAt DateTime @default(now())
}
