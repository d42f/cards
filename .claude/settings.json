{
  "permissions": {
    "allow": [
      "Bash(npx tsc:*)",
      "Bash(npx prisma generate:*)",
      "Bash(npm install:*)",
      "Bash(npm run:*)",
      "Bash(node -e \":*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(npx prisma migrate dev:*)",
      "Bash(npx husky init)",
      "Bash(npx eslint:*)",
      "Skill(update-config:*)",
      "Bash(where pnpm:*)",
      "Bash(pnpm --version)",
      "Bash(rm -f package-lock.json)",
      "Bash(pnpm install:*)",
      "Bash(pnpm approve-builds:*)",
      "Bash(npx create-expo-app:*)",
      "Bash(grep)",
      "Bash(pnpm lint:*)",
      "Bash(systeminfo)",
      "Bash(pnpm add:*)",
      "Bash(pnpm exec:*)",
      "Bash(pnpm format:check)",
      "Bash(pnpm format:*)",
      "Bash(xargs grep *)",
      "Bash(npx prisma *)",
      "Bash(grep -v \"//\")",
      "Bash(./node_modules/.bin/tsc --noEmit)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "npm run format 2>/dev/null || true",
            "statusMessage": "Running Prettier..."
          }
        ]
      }
    ]
  }
}
