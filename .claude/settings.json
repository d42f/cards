{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "npm run format 2>/dev/null || true",
            "statusMessage": "Running Prettier..."
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(npx tsc:*)",
      "Bash(npx prisma generate:*)",
      "Bash(npm install:*)",
      "Bash(npm run:*)",
      "Bash(node -e \":*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(npx prisma migrate dev:*)",
      "Bash(npx husky init)",
      "Bash(npx eslint:*)",
      "Skill(update-config:*)"
    ]
  }
}
