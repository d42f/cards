{
  "name": "cards",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "dev:web": "pnpm --filter @cards/web dev",
    "dev:mobile": "pnpm --filter @cards/web --filter @cards/mobile dev",
    "dev:android": "pnpm --filter @cards/mobile android",
    "build": "turbo build",
    "build:web": "pnpm --filter @cards/web build",
    "build:mobile": "pnpm --filter @cards/mobile build",
    "lint": "turbo lint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky"
  },
  "lint-staged": {
    "apps/web/**/*.{ts,tsx,js,mjs,cjs}": [
      "eslint --config apps/web/eslint.config.mjs --fix",
      "prettier --write"
    ],
    "**/*.{json,md,yml,yaml,css}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.2",
    "@commitlint/config-conventional": "^20.4.2",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.2",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "turbo": "^2.5.4"
  },
  "engines": {
    "npm": "please-use-pnpm",
    "yarn": "please-use-pnpm"
  },
  "packageManager": "pnpm@10.10.0",
  "pnpm": {
    "peerDependencyRules": {
      "allowedVersions": {
        "react-dom": "19.1.0"
      }
    },
    "onlyBuiltDependencies": [
      "@apollo/protobufjs",
      "@prisma/engines",
      "better-sqlite3",
      "prisma",
      "sharp",
      "unrs-resolver"
    ]
  }
}
